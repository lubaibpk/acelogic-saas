{
  "version": 2,
  "name": "acelogic-saas",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_SERVICE_KEY": "@supabase_service_key",
    "JWT_SECRET": "@jwt_secret",
    "REGISTER_SECRET": "@register_secret",
    "KEY_ENCRYPT_SECRET": "@key_encrypt_secret"
  }
}
